# ============================================================
# FuelTracks Voice Calling Agent — .gitignore
# ============================================================

# ── Secrets & Credentials ───────────────────────────────────
# NEVER commit real credentials to version control
.env
*.pem
*.key
*.crt
*.p12
secrets/

# ── Python byte-code & caches ───────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/
.tox/

# ── Local databases ─────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── Log files ───────────────────────────────────────────────
*.log
logs/
server.log

# ── Scratch / ad-hoc test scripts ───────────────────────────
# These are local development experiments, not production code
scratch/

# ── Excel / data files (except the sample template) ─────────
*.xlsx
!customers_sample.xlsx
*.csv

# ── Docker volumes & overrides ──────────────────────────────
docker-compose.override.yml
postgres-data/

# ── IDE & Editor ─────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.user
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Virtual environments ─────────────────────────────────────
venv/
.venv/
env/
ENV/
.env.bak

# ── Build artifacts ──────────────────────────────────────────
build/
dist/
*.egg-info/
*.egg
.eggs/
wheels/

# ── OS generated files ───────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Desktop.ini