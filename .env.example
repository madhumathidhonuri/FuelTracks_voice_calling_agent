# Telephony config
EXOTEL_ACCOUNT_SID=your_exotel_account_sid
EXOTEL_API_KEY=your_exotel_api_key
EXOTEL_API_TOKEN=your_exotel_api_token
EXOTEL_CALLER_ID=your_exotel_virtual_number
EXOTEL_API_URL=https://api.in.exotel.com

# AI/API keys
SARVAM_API_KEY=your_sarvam_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
GEMINI_API_KEY=your_gemini_api_key

# App settings
DATABASE_URL=sqlite:///voice_calling.db
HOST=0.0.0.0
PORT=8000
# WebSocket URL exposed to Exotel. Run scripts/update_ngrok_url.py to auto-populate
# this with your active ngrok tunnel URL when testing locally.
WEBSOCKET_URL=ws://localhost:8000/ws/media
